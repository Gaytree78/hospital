<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F4F7">

    <!-- Main Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingBottom="72dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ─────────────────────────────── -->
            <!-- TOP APP BAR                     -->
            <!-- ─────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="#FFFFFF">

                <!-- App Logo / Icon -->
                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_app_logo"
                    android:background="@drawable/bg_logo_icon"
                    android:padding="6dp"
                    android:contentDescription="App Logo" />

                <!-- Spacer -->
                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <!-- Settings Icon -->
                <ImageView
                    android:id="@+id/ivSettings"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_settings"
                    android:padding="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Settings"
                    app:tint="#6B7280" />

            </LinearLayout>

            <!-- Spacer -->
            <View android:layout_width="match_parent" android:layout_height="12dp" />

            <!-- ─────────────────────────────── -->
            <!-- SEARCH BAR                      -->
            <!-- ─────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_input_field"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:clickable="true"
                android:focusable="true"
                android:id="@+id/searchBar">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_search"
                    android:contentDescription="Search Icon"
                    android:layout_marginEnd="8dp"
                    app:tint="#9CA3AF" />

                <!-- ✅ Not editable — acts as a button to open SearchPatientActivity -->
                <EditText
                    android:id="@+id/etSearch"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="Search patients by name or ID..."
                    android:textColorHint="#9CA3AF"
                    android:textColor="#1A1A2E"
                    android:textSize="13sp"
                    android:background="@null"
                    android:singleLine="true"
                   android:inputType="text"

                    android:clickable="true"
                    android:cursorVisible="false"/>

                <ImageView
                    android:id="@+id/ivFilter"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_filter"
                    android:contentDescription="Filter Icon"
                    android:clickable="true"
                    android:focusable="true"
                    app:tint="#9CA3AF" />

            </LinearLayout>
            <!-- Spacer -->
            <View android:layout_width="match_parent" android:layout_height="12dp" />

            <!-- ─────────────────────────────── -->
            <!-- STATS CARDS ROW                 -->
            <!-- ─────────────────────────────── -->
            <!-- STATS CARDS ROW -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:weightSum="2">

                <!-- Total Patients Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_group"
                                android:contentDescription="Patients Icon"
                                app:tint="#2563EB" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="0dp"
                                android:layout_weight="1"/>



                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="8dp" />

                        <!-- ✅ ID on the count TextView -->
                        <TextView
                            android:id="@+id/tvTotalPatients"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="..."
                            android:textColor="#111827"
                            android:textSize="26sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TOTAL PATIENTS"
                            android:textColor="#9CA3AF"
                            android:textSize="10sp"
                            android:letterSpacing="0.08"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Visits Today Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#EFF6FF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_pulse"
                                android:contentDescription="Visits Icon"
                                app:tint="#2563EB" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="0dp"
                                android:layout_weight="1"/>



                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="8dp" />

                        <!-- ✅ ID on the count TextView — different from tvTotalPatients -->
                        <TextView
                            android:id="@+id/tvTodayVisits"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="..."
                            android:textColor="#111827"
                            android:textSize="26sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="VISITS TODAY"
                            android:textColor="#9CA3AF"
                            android:textSize="10sp"
                            android:letterSpacing="0.08"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- Spacer -->
            <View android:layout_width="match_parent" android:layout_height="12dp" />

            <!-- ─────────────────────────────── -->
            <!-- ADD NEW PATIENT BANNER          -->
            <!-- ─────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardAddPatient"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#2563EB"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">

                    <!-- Person + Plus Icon -->
                    <ImageView
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:src="@drawable/ic_person_add"
                        android:background="@drawable/bg_add_patient_icon"
                        android:padding="8dp"

                        android:contentDescription="Add Patient Icon"
                        app:tint="#FFFFFF" />

                    <!-- Text Block -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Add New Patient"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:clickable="true"
                            android:focusable="true"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Create a comprehensive medical record"
                            android:textColor="#BFDBFE"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                    <!-- Plus Icon -->
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_add"
                        android:contentDescription="Add Icon"
                        app:tint="#FFFFFF" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Spacer -->
            <View android:layout_width="match_parent" android:layout_height="16dp" />

            <!-- ─────────────────────────────── -->
            <!-- RECENT ACTIVITY HEADER          -->
            <!-- ─────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="10dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_clock"
                    android:contentDescription="Recent Activity Icon"
                    app:tint="#2563EB" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="RECENT ACTIVITY"
                    android:textColor="#374151"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvViewAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View All"
                    android:textColor="#2563EB"
                    android:textSize="12sp"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <!-- ─────────────────────────────── -->
            <!-- ACTIVITY LIST CARD              -->
            <!-- ─────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:id="@+id/recentActivityList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- ── Patient 1: Sarah Jenkins ── -->
                    <LinearLayout
                        android:id="@+id/itemSarahJenkins"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="14dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">

                        <TextView
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:text="SJ"
                            android:textColor="#2563EB"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:background="@drawable/bg_avtar_circle" />
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Sarah Jenkins"
                                    android:textColor="#111827"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="10m ago"
                                    android:textColor="#9CA3AF"
                                    android:textSize="11sp" />

                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Record updated: Added recent ECG results"
                                android:textColor="#6B7280"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ID: ML-4829"
                                android:textColor="#9CA3AF"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_arrow_right"
                            android:layout_marginStart="8dp"
                            android:contentDescription="View Arrow"
                            app:tint="#D1D5DB" />

                    </LinearLayout>

                    <!-- Divider -->
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F3F4F6" android:layout_marginStart="68dp" />

                    <!-- ── Patient 2: Michael Chen ── -->
                    <LinearLayout
                        android:id="@+id/itemMichaelChen"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="14dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">

                        <TextView
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:text="MC"
                            android:textColor="#2563EB"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:background="@drawable/bg_avtar_circle" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Michael Chen"
                                    android:textColor="#111827"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="45m ago"
                                    android:textColor="#9CA3AF"
                                    android:textSize="11sp" />

                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="New patient record created"
                                android:textColor="#6B7280"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ID: ML-3021"
                                android:textColor="#9CA3AF"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_arrow_right"
                            android:layout_marginStart="8dp"
                            android:contentDescription="View Arrow"
                            app:tint="#D1D5DB" />

                    </LinearLayout>

                    <!-- Divider -->
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F3F4F6" android:layout_marginStart="68dp" />

                    <!-- ── Patient 3: Eleanor Vance ── -->
                    <LinearLayout
                        android:id="@+id/itemEleanorVance"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="14dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">

                        <TextView
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:text="EV"
                            android:textColor="#2563EB"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:background="@drawable/bg_avtar_circle" />
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Eleanor Vance"
                                    android:textColor="#111827"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="2h ago"
                                    android:textColor="#9CA3AF"
                                    android:textSize="11sp" />

                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Visit logged: Routine hypertension check"
                                android:textColor="#6B7280"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ID: ML-1192"
                                android:textColor="#9CA3AF"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_arrow_right"
                            android:layout_marginStart="8dp"
                            android:contentDescription="View Arrow" app:tint="#D1D5DB" />

                    </LinearLayout>

                    <!-- Divider -->
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F3F4F6" android:layout_marginStart="68dp" />

                    <!-- ── Patient 4: Robert Taylor ── -->
                    <LinearLayout
                        android:id="@+id/itemRobertTaylor"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="14dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">

                        <TextView
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:text="RT"
                            android:textColor="#2563EB"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:background="@drawable/bg_avtar_circle" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Robert Taylor"
                                    android:textColor="#111827"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="5h ago"
                                    android:textColor="#9CA3AF"
                                    android:textSize="11sp" />

                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Allergy information updated: Penicillin"
                                android:textColor="#6B7280"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ID: ML-3304"
                                android:textColor="#9CA3AF"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_arrow_right"
                            android:layout_marginStart="8dp"
                            android:contentDescription="View Arrow"
                            app:tint="#D1D5DB" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Spacer -->
            <View android:layout_width="match_parent" android:layout_height="16dp" />

        </LinearLayout>

    </ScrollView>

    <!-- ─────────────────────────────── -->
    <!-- FAB: Floating + Button          -->
    <!-- ─────────────────────────────── -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAdd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="80dp"
        android:src="@drawable/ic_add"
        app:backgroundTint="#2563EB"
        app:tint="#FFFFFF"
        app:fabSize="normal"
        app:elevation="6dp"
        android:contentDescription="Add New Patient" />

    <!-- ─────────────────────────────── -->
    <!-- BOTTOM NAVIGATION BAR           -->
    <!-- ─────────────────────────────── -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled"
        app:itemIconTint="@color/bottom_nav_color"
        app:itemTextColor="@color/bottom_nav_color"
        app:elevation="8dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>