<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- TOP BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:background="#FFFFFF">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_arrow_back" />

            <TextView
                android:id="@+id/tvTopName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Patient Name"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="12dp"/>

        </LinearLayout>

        <!-- PROFILE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:background="#FFFFFF">

            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/ic_person_outline"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/tvName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Name"
                    android:textStyle="bold"
                    android:textSize="16sp"/>

                <TextView
                    android:id="@+id/tvPatientInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ID • Status"
                    android:textColor="#777"
                    android:textSize="12sp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- INFO BOX -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp">

            <!-- AGE -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:background="#EAF2FF"
                android:gravity="center"
                android:orientation="vertical"
                android:layout_marginEnd="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AGE"
                    android:textSize="10sp"/>
                <TextView
                    android:id="@+id/tvAge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- GENDER -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:background="#EAF2FF"
                android:gravity="center"
                android:orientation="vertical"
                android:layout_marginEnd="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GENDER"
                    android:textSize="10sp"/>
                <TextView
                    android:id="@+id/tvGender"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- BLOOD -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:background="#EAF2FF"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BLOOD"
                    android:textSize="10sp"/>
                <TextView
                    android:id="@+id/tvBlood"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textStyle="bold"/>
            </LinearLayout>

        </LinearLayout>

        <!-- SYMPTOMS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SYMPTOMS"
                android:textColor="#777"
                android:textSize="12sp"/>
            <TextView
                android:id="@+id/tvSymptoms"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- DIAGNOSIS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="#FFFFFF"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DISEASE / DIAGNOSIS"
                android:textColor="#777"
                android:textSize="12sp"/>
            <TextView
                android:id="@+id/tvDiagnosis"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- TREATMENT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="#FFFFFF"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TREATMENT GIVEN"
                android:textSize="12sp"
                android:textColor="#777"/>
            <TextView
                android:id="@+id/tvTreatment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#059669"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- CONTACT -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CONTACT and LOGISTICS"
            android:textStyle="bold"
            android:padding="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:orientation="vertical"
            android:background="#FFFFFF">

            <TextView
                android:id="@+id/tvMobile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📞 --"/>
            <TextView
                android:id="@+id/tvAddress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏠 --"
                android:layout_marginTop="6dp"/>
            <TextView
                android:id="@+id/tvEmergency"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚨 --"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <!-- VISIT HISTORY HEADER + BUTTON -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="VISIT HISTORY"
                android:textStyle="bold"
                android:textSize="13sp"
                android:textColor="#374151"/>

            <TextView
                android:id="@+id/btnAddVisit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+ Add Visit"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_blue_button"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:clickable="true"
                android:focusable="true"/>

        </LinearLayout>

        <!-- Visit History Timeline -->
        <LinearLayout
            android:id="@+id/timelineContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/tvNoVisits"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No visit history yet."
                android:textColor="#9CA3AF"
                android:textSize="13sp"
                android:padding="16dp"/>

        </LinearLayout>

        <!-- SEND MESSAGE BUTTON -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:gravity="center">

            <TextView
                android:id="@+id/btnSendMessage"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="💬 Send Message"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@drawable/bg_blue_button"
                android:clickable="true"
                android:focusable="true"/>

        </LinearLayout>

        <!-- SHARE & PDF BUTTONS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/btnGeneratePDF"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="📄 Generate PDF"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/bg_blue_button"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <!-- ─────────────────────────────── -->
        <!-- REPORTS SECTION                 -->
        <!-- ─────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="REPORTS"
            android:textStyle="bold"
            android:padding="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp">

            <!-- ── Blood Report ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🩸 Blood Report"
                android:textColor="#374151"
                android:textStyle="bold"
                android:textSize="13sp"/>

            <!-- Image preview (shown for image files) -->
            <ImageView
                android:id="@+id/imgBloodReport"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scaleType="fitCenter"
                android:adjustViewBounds="true"
                android:visibility="gone"
                android:layout_marginTop="8dp"
                android:contentDescription="Blood Report Image"/>

            <!-- PDF link (shown for PDF files) -->
            <TextView
                android:id="@+id/tvBloodPdfLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📄 Open Blood Report (PDF)"
                android:textColor="#2563EB"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingTop="8dp"
                android:paddingBottom="4dp"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone"/>

            <!-- Fallback: nothing uploaded -->
            <TextView
                android:id="@+id/tvNoBloodReport"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No blood report uploaded"
                android:textColor="#9CA3AF"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F3F4F6"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="14dp"/>

            <!-- ── Urine Report ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🧪 Urine Report"
                android:textColor="#374151"
                android:textStyle="bold"
                android:textSize="13sp"/>

            <!-- Image preview -->
            <ImageView
                android:id="@+id/imgUrineReport"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scaleType="fitCenter"
                android:adjustViewBounds="true"
                android:visibility="gone"
                android:layout_marginTop="8dp"
                android:contentDescription="Urine Report Image"/>

            <!-- PDF link -->
            <TextView
                android:id="@+id/tvUrinePdfLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📄 Open Urine Report (PDF)"
                android:textColor="#2563EB"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingTop="8dp"
                android:paddingBottom="4dp"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone"/>

            <!-- Fallback -->
            <TextView
                android:id="@+id/tvNoUrineReport"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No urine report uploaded"
                android:textColor="#9CA3AF"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F3F4F6"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="14dp"/>

            <!-- ── General File ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📎 General File / Lab Report"
                android:textColor="#374151"
                android:textStyle="bold"
                android:textSize="13sp"/>

            <!-- Tappable link for general file (image or PDF) -->
            <TextView
                android:id="@+id/tvGeneralFileLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📄 Open General File"
                android:textColor="#2563EB"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingTop="8dp"
                android:paddingBottom="4dp"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- Bottom spacer -->
        <View android:layout_width="match_parent" android:layout_height="24dp"/>

    </LinearLayout>

</ScrollView>