<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── HEADER ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/splash_bg"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="48dp"
            android:paddingBottom="40dp">

            <!-- Top row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Welcome back 👋"
                        android:textColor="#1E3A8A"
                        android:textSize="13sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Krishnai Clinic"
                        android:textColor="#1E3A8A"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Smart Patient Management"
                        android:textColor="#1E3A8A"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp"/>

                </LinearLayout>

                <!-- Avatar -->
                <LinearLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:background="@drawable/bg_avtar_white">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DR"
                        android:textColor="#2563EB"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                </LinearLayout>

            </LinearLayout>

            <!-- ── STATS INSIDE HEADER ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="24dp"
                android:weightSum="3">

                <!-- Patients -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_stat_glass"
                    android:padding="10dp"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:id="@+id/tvDashTotalPatients"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#1E3A8A"
                        android:textSize="20sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Patients"
                        android:textColor="#1E3A8A"
                        android:textSize="10sp"
                        android:layout_marginTop="2dp"/>

                </LinearLayout>

                <!-- Today -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_stat_glass"
                    android:padding="10dp"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:id="@+id/tvDashTodayVisits"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#1E3A8A"
                        android:textSize="20sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Today"
                        android:textColor="#1E3A8A"
                        android:textSize="10sp"
                        android:layout_marginTop="2dp"/>

                </LinearLayout>

                <!-- Today Revenue stat pill (header) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_stat_glass"
                    android:padding="10dp">

                    <TextView
                        android:id="@+id/tvDashHeaderRevenue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#1E3A8A"
                        android:textSize="20sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹ Today"
                        android:textColor="#1E3A8A"
                        android:textSize="10sp"
                        android:layout_marginTop="2dp"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- ── SECTION LABEL ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="QUICK ACTIONS"
            android:textColor="#6B7280"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:paddingStart="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="12dp"/>

        <!-- ── CARDS ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <!-- Row 1: Add + View -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- Add Patient -->
                <LinearLayout
                    android:id="@+id/cardAdd"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/splash_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:elevation="4dp">

                    <TextView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="➕"
                        android:textSize="16sp"
                        android:gravity="center"
                        android:background="@drawable/bg_icon_white_alpha"/>

                    <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Add Patient"
                        android:textColor="#1E3A8A"
                        android:textSize="13sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="New record"
                        android:textColor="#1E3A8A"
                        android:textSize="11sp"
                        android:layout_marginTop="2dp"/>

                </LinearLayout>

                <!-- View Patients -->
                <LinearLayout
                    android:id="@+id/cardView"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/splash_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:elevation="2dp">

                    <TextView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="📋"
                        android:textSize="16sp"
                        android:gravity="center"
                        android:background="@drawable/bg_icon_blue_light"/>

                    <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View Patients"
                        android:textColor="#1E3A8A"
                        android:textSize="13sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="All records"
                        android:textColor="#1E3A8A"
                        android:textSize="11sp"
                        android:layout_marginTop="2dp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Row 2: Search + Reports -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- Search -->
                <LinearLayout
                    android:id="@+id/cardSearch"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/splash_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:elevation="2dp">

                    <TextView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="🔍"
                        android:textSize="16sp"
                        android:gravity="center"
                        android:background="@drawable/bg_icon_blue_light"/>

                    <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Search"
                        android:textColor="#1E3A8A"
                        android:textSize="13sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Find patient"
                        android:textColor="#1E3A8A"
                        android:textSize="11sp"
                        android:layout_marginTop="2dp"/>

                </LinearLayout>
            </LinearLayout>

            <!-- ─────────────────────────────────────────────────── -->
            <!-- Row 3: TODAY'S REVENUE (full width green card) NEW  -->
            <!-- ─────────────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:id="@+id/cardRevenue"
                    android:layout_width="match_parent"
                    android:layout_height="130dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="20dp"
                    android:background="@drawable/splash_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:elevation="4dp">

                    <!-- Left: icon + label -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:text="💰"
                            android:textSize="18sp"
                            android:gravity="center"
                            />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Today's Revenue"
                            android:textColor="#1E3A8A"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="12dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹100 per visit · resets daily"
                            android:textColor="#1E3A8A"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                    <!-- Right: big rupee amount -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">

                        <TextView
                            android:id="@+id/tvRevenueAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹ --"
                            android:textColor="#FFFFFF"
                            android:textSize="32sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvRevenueVisitCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-- visits today"
                            android:textColor="#1E3A8A"
                            android:textSize="12sp"
                            android:gravity="center"
                            android:layout_marginTop="4dp"/>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>
            <!-- END Row 3: Revenue -->

            <!-- Row 4: Appointments + Logout -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="32dp">

                <!-- Appointments -->
                <LinearLayout
                    android:id="@+id/cardAppointment"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/splash_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:elevation="2dp">

                    <TextView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="📅"
                        android:textSize="16sp"
                        android:gravity="center"
                        android:background="@drawable/bg_icon_blue_light"/>

                    <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Appointments"
                        android:textColor="#1E3A8A"
                        android:textSize="13sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Coming soon"
                        android:textColor="#9CA3AF"
                        android:textSize="11sp"
                        android:layout_marginTop="2dp"/>

                </LinearLayout>

                <!-- Logout -->
                <LinearLayout
                    android:id="@+id/cardLogout"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/splash_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:elevation="2dp">

                    <TextView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="🚪"
                        android:textSize="16sp"
                        android:gravity="center"
                        android:background="@drawable/bg_icon_blue_light"/>

                    <View android:layout_width="1dp" android:layout_height="0dp" android:layout_weight="1"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Logout"
                        android:textColor="#1E3A8A"
                        android:textSize="13sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sign out safely"
                        android:textColor="#1E3A8A"
                        android:textSize="11sp"
                        android:layout_marginTop="2dp"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>